generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  DOCTOR
  RECEPTIONIST
}

enum AppointmentStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum QueueStatus {
  WAITING
  CALLING
  COMPLETED
  SKIPPED
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(RECEPTIONIST)
  createdAt DateTime @default(now())

  doctor Doctor?
}

// FIXED: Duplicate booking prevention enforced via a Partial Unique Index
// (unique_active_booking) on (doctorId, appointmentDate) WHERE status != 'CANCELLED',
// applied as a raw SQL migration in prisma/migrations/.
model Doctor {
  id              String   @id @default(uuid())
  userId          String?  @unique
  user            User?    @relation(fields: [userId], references: [id])
  name            String
  specialization  String
  department      String
  consultationFee Float
  experience      Int
  availableFrom   String   @default("09:00")
  availableTo     String   @default("17:00")
  createdAt       DateTime @default(now())

  // FIXED: Added indices on department and specialization to prevent full table scans.
  @@index([department])
  @@index([specialization])

  appointments Appointment[]
  queueTokens  QueueToken[]
}

model Patient {
  id             String   @id @default(uuid())
  name           String
  email          String?
  phoneNumber    String
  age            Int
  gender         String
  medicalHistory String?  // Nullable — handled safely on frontend with optional chaining
  createdAt      DateTime @default(now())

  appointments Appointment[]
  queueTokens  QueueToken[]
}

model Appointment {
  id              String            @id @default(uuid())
  patientId       String
  patient         Patient           @relation(fields: [patientId], references: [id])
  doctorId        String
  doctor          Doctor            @relation(fields: [doctorId], references: [id])
  appointmentDate DateTime
  reason          String            @default("")
  status          AppointmentStatus @default(PENDING)
  consultationFee Float             @default(0)
  createdAt       DateTime          @default(now())

  @@index([doctorId, status])
  @@index([patientId])
  @@index([appointmentDate])

  // FIXED: Added indices on (doctorId, status), patientId, and appointmentDate.
  queueTokens QueueToken[]
}

model QueueToken {
  id            String      @id @default(uuid())
  tokenNumber   Int
  patientId     String
  patient       Patient     @relation(fields: [patientId], references: [id])
  doctorId      String
  doctor        Doctor      @relation(fields: [doctorId], references: [id])
  appointmentId String?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  status        QueueStatus @default(WAITING)
  createdAt     DateTime    @default(now())

  @@index([doctorId, createdAt])
  @@index([status])

  // FIXED: Added indices on (doctorId, createdAt) and status for query performance.
  // Race condition on (doctorId, tokenNumber) mitigated via FOR UPDATE row lock
  // inside a Prisma $transaction with retry logic in the checkin route.
}
